<Page
    x:Class="PasskeyManager.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:PasskeyManager"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">
    <Page.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary>
                    <local:BitwiseFlagToVisibilityConverter x:Key="BitwiseFlagToVisibilityConverter" />
                    <SolidColorBrush x:Key="SystemFillColorSuccessBrush" Color="{ThemeResource SystemFillColorSuccess}" />
                    <SolidColorBrush x:Key="SystemFillColorCriticalBrush" Color="{ThemeResource SystemFillColorCritical}" />
                    <SolidColorBrush x:Key="SystemFillColorCautionBrush" Color="{ThemeResource SystemFillColorCaution}" />
                    <SolidColorBrush x:Key="SystemFillColorNeutralBrush" Color="{ThemeResource SystemFillColorNeutral}" />
                    <Style x:Key="CardStyle" TargetType="Grid">
                        <Style.Setters>
                            <Setter Property="Background" Value="{ThemeResource CardBackgroundFillColorDefaultBrush}" />
                            <Setter Property="BorderThickness" Value="1" />
                            <Setter Property="Padding" Value="12" />
                            <Setter Property="BorderBrush" Value="{ThemeResource CardStrokeColorDefaultBrush}" />
                            <Setter Property="CornerRadius" Value="{StaticResource OverlayCornerRadius}" />
                        </Style.Setters>
                    </Style>
                </ResourceDictionary>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Page.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="48" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <StackPanel Orientation="Horizontal">
            <Image
                Width="16"
                Height="16"
                Margin="16,0,8,0"
                Source="ms-appx:///Assets/icon.ico" />
            <TextBlock
                VerticalAlignment="Center"
                Style="{StaticResource CaptionTextBlockStyle}"
                Text="HappyFactory Passkey Manager" />
        </StackPanel>
        <Grid Grid.Row="1">
            <Grid
                x:Name="homeViewRoot"
                Padding="16,24,16,16"
                RowSpacing="16"
                Visibility="Visible">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Spacing="4">
                        <TextBlock Style="{StaticResource TitleTextBlockStyle}" Text="パスキー一覧" />
                        <TextBlock
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            Text="検索しながら登録済みパスキーを確認できます。詳細設定は右上のボタンから開きます。"
                            TextWrapping="WrapWholeWords" />
                    </StackPanel>
                    <Button
                        x:Name="showDetailViewButton"
                        Grid.Column="1"
                        Click="showDetailViewButton_Click"
                        Content="詳細"
                        Style="{StaticResource AccentButtonStyle}" />
                </Grid>

                <Grid
                    Grid.Row="1"
                    Style="{StaticResource CardStyle}">
                    <Grid RowSpacing="12">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid Grid.Row="0" ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <AutoSuggestBox
                                x:Name="passkeySearchBox"
                                Grid.Column="0"
                                PlaceholderText="ユーザー名 / RP 名で検索"
                                TextChanged="passkeySearchBox_TextChanged" />
                            <Button
                                x:Name="clearPasskeySearchButton"
                                Grid.Column="1"
                                Click="clearPasskeySearchButton_Click"
                                Content="クリア"
                                Visibility="Collapsed" />
                        </Grid>
                        <TextBlock
                            x:Name="homeCredentialSummaryTextBlock"
                            Grid.Row="1"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            Text="パスキーを読み込み中..."
                            TextWrapping="WrapWholeWords" />
                    </Grid>
                </Grid>

                <Grid
                    Grid.Row="2"
                    Style="{StaticResource CardStyle}">
                    <ListView
                        x:Name="homeCredentialListView"
                        IsItemClickEnabled="True"
                        ItemClick="homeCredentialListView_ItemClick"
                        SelectionMode="None">
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="local:Credential">
                                <Grid Padding="8" ColumnSpacing="8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="28" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <FontIcon
                                        Grid.RowSpan="3"
                                        Grid.Column="0"
                                        FontSize="16"
                                        Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"
                                        Glyph="&#xF427;" />
                                    <TextBlock Grid.Column="1" Text="{x:Bind UserName}" />
                                    <TextBlock
                                        Grid.Row="1"
                                        Grid.Column="1"
                                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                        Style="{StaticResource CaptionTextBlockStyle}"
                                        Text="{x:Bind RpName}" />
                                    <TextBlock
                                        Grid.Row="2"
                                        Grid.Column="1"
                                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                        Style="{StaticResource CaptionTextBlockStyle}">
                                        <Run Text="作成: " />
                                        <Run Text="{x:Bind CreatedAtDisplay}" />
                                        <Run Text="  更新: " />
                                        <Run Text="{x:Bind UpdatedAtDisplay}" />
                                    </TextBlock>
                                    <Border
                                        Grid.RowSpan="3"
                                        Grid.Column="2"
                                        Padding="4"
                                        VerticalAlignment="Center"
                                        Background="{ThemeResource ControlAltFillColorSecondaryBrush}"
                                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                        BorderThickness="1"
                                        CornerRadius="{StaticResource ControlCornerRadius}"
                                        Visibility="{x:Bind CredentialOptions, Converter={StaticResource BitwiseFlagToVisibilityConverter}, ConverterParameter=AutofillCapable}">
                                        <TextBlock FontSize="12" Text="Autofill" />
                                    </Border>
                                    <Border
                                        Grid.RowSpan="3"
                                        Grid.Column="3"
                                        Padding="4"
                                        VerticalAlignment="Center"
                                        Background="{ThemeResource SystemFillColorCriticalBackgroundBrush}"
                                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                        BorderThickness="1"
                                        CornerRadius="{StaticResource ControlCornerRadius}"
                                        Visibility="{x:Bind CredentialOptions, Converter={StaticResource BitwiseFlagToVisibilityConverter}, ConverterParameter=MetadataStale}">
                                        <TextBlock
                                            FontSize="12"
                                            Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                                            Text="Stale" />
                                    </Border>
                                    <StackPanel
                                        Grid.RowSpan="3"
                                        Grid.Column="4"
                                        Margin="8,0,0,0"
                                        VerticalAlignment="Center"
                                        Orientation="Horizontal"
                                        Spacing="4">
                                        <TextBlock
                                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                            Style="{StaticResource CaptionTextBlockStyle}"
                                            Text="詳細" />
                                        <FontIcon
                                            FontSize="12"
                                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                            Glyph="&#xE76C;" />
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                    <Border
                        x:Name="homeCredentialEmptyStateContainer"
                        Background="Transparent"
                        Visibility="Collapsed">
                        <TextBlock
                            x:Name="homeCredentialEmptyStateTextBlock"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            Text="一致するパスキーがありません。"
                            TextWrapping="WrapWholeWords" />
                    </Border>
                </Grid>
            </Grid>

            <ScrollViewer
                x:Name="detailViewScroller"
                Padding="0"
                VerticalScrollBarVisibility="Auto"
                Visibility="Collapsed">
                <Grid
                    Padding="16,24,16,16"
                    ColumnSpacing="24"
                    RowSpacing="8"
                    Visibility="Visible">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid Grid.ColumnSpan="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Spacing="4">
                    <TextBlock Style="{StaticResource TitleTextBlockStyle}" Text="詳細" />
                    <TextBlock
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Text="プラグイン状態、同期設定、ログ、パスキー管理をまとめて確認できます。"
                        TextWrapping="WrapWholeWords" />
                    <TextBlock Style="{StaticResource BodyStrongTextBlockStyle}" Text="Plugin" />
                </StackPanel>
                <Button
                    x:Name="backToHomeButton"
                    Grid.Column="1"
                    Click="backToHomeButton_Click"
                    Content="ホームへ戻る" />
            </Grid>
            <Grid
                Grid.Row="1"
                Grid.ColumnSpan="2"
                Padding="12"
                Style="{StaticResource CardStyle}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="pluginStateTextBlock" VerticalAlignment="Center">
                    <Run Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="State:" />
                    <Run
                        x:Name="pluginStateRun"
                        Foreground="{ThemeResource SystemFillColorCautionBrush}"
                        Text="" />
                </TextBlock>
                <StackPanel
                    Grid.Column="1"
                    Orientation="Horizontal"
                    Spacing="8">
                    <Button
                        x:Name="registerPluginButton"
                        Click="registerPluginButton_Click"
                        Content="プラグインを登録"
                        Style="{StaticResource AccentButtonStyle}" />
                    <Button
                        x:Name="updatePluginButton"
                        Click="updatePluginButton_Click"
                        Content="プラグインを更新"
                        Style="{StaticResource AccentButtonStyle}" />
                    <Button
                        x:Name="activatePluginButton"
                        Click="activatePluginButton_Click"
                        Content="プラグインを有効化"
                        Style="{StaticResource AccentButtonStyle}" />
                    <Button
                        x:Name="unregisterPluginButton"
                        Click="unregisterPluginButton_Click"
                        Content="プラグイン登録を解除" />
                </StackPanel>
                <TextBlock
                    x:Name="pluginActivationHintText"
                    Grid.Row="1"
                    Grid.ColumnSpan="2"
                    Margin="0,8,0,0"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    Text=""
                    TextWrapping="WrapWholeWords"
                    Visibility="Collapsed" />
            </Grid>


            <TextBlock
                Grid.Row="2"
                Margin="0,16,0,0"
                Style="{StaticResource BodyStrongTextBlockStyle}"
                Text="Stats" />
            <Grid Grid.Row="3" Style="{StaticResource CardStyle}">
                <InfoBarPanel>
                    <TextBlock x:Name="credentialStateTextBlock1">
                        <Run Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="Local DB:" />
                        <Run x:Name="credsStatsRun1" Text="Not available" />
                        <LineBreak /><Run Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="Windows Cache Stats:" />
                        <Run x:Name="credsStatsRun2" Text="Not available" />
                    </TextBlock>
                </InfoBarPanel>
            </Grid>
            <TextBlock
                Grid.Row="2"
                Grid.Column="1"
                Margin="0,16,0,0"
                Style="{StaticResource BodyStrongTextBlockStyle}"
                Text="Configuration" />
            <Grid
                Grid.Row="3"
                Grid.Column="1"
                Style="{StaticResource CardStyle}">
                <Grid RowSpacing="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <StackPanel
                        Grid.Row="0"
                        Orientation="Horizontal"
                        Spacing="8">
                        <ToggleSplitButton
                            x:Name="VaultUnlockControl"
                            Content="Vault Unlocked"
                            IsCheckedChanged="VaultUnlockControl_IsCheckedChanged">
                            <ToggleSplitButton.Flyout>
                                <Flyout Placement="Bottom">
                                    <ToggleSwitch
                                        x:Name="vaultLockSwitch"
                                        Header="Unlock Method"
                                        IsOn="False"
                                        OffContent="Consent"
                                        OnContent="Passkey"
                                        Toggled="vaultLockSwitch_Toggled">
                                        <ToggleSwitch.HeaderTemplate>
                                            <DataTemplate>
                                                <TextBlock
                                                    Margin="0,0,0,0"
                                                    Padding="0,0,0,0"
                                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                    Text="{Binding}" />
                                            </DataTemplate>
                                        </ToggleSwitch.HeaderTemplate>
                                    </ToggleSwitch>
                                </Flyout>
                            </ToggleSplitButton.Flyout>
                        </ToggleSplitButton>
                        <ToggleSwitch
                            x:Name="silentOperationSwitch"
                            Header="Minimize UI"
                            IsOn="False"
                            OffContent="Show"
                            OnContent="Hide"
                            Toggled="silentOperationSwitch_Toggled">
                            <ToggleSwitch.HeaderTemplate>
                                <DataTemplate>
                                    <TextBlock
                                        Margin="0,0,0,0"
                                        Padding="0,0,0,0"
                                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                        Text="{Binding}" />
                                </DataTemplate>
                            </ToggleSwitch.HeaderTemplate>
                        </ToggleSwitch>
                        <TextBlock
                            x:Name="vaultRecoveryHintText"
                            Foreground="{ThemeResource SystemFillColorCautionBrush}"
                            Text=""
                            TextWrapping="WrapWholeWords"
                            Visibility="Collapsed" />
                        <Button
                            x:Name="runVaultRecoveryButton"
                            Click="runVaultRecoveryButton_Click"
                            Content="Run Vault Recovery"
                            Visibility="Collapsed" />
                    </StackPanel>

                    <Grid
                        Grid.Row="1"
                        ColumnSpacing="8"
                        RowSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock
                            Grid.Row="0"
                            Grid.Column="0"
                            VerticalAlignment="Center"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            Text="Sync Base URL" />
                        <TextBox
                            x:Name="syncBaseUrlTextBox"
                            Grid.Row="0"
                            Grid.Column="1"
                            MinHeight="28"
                            Padding="8,2"
                            PlaceholderText="https://tsupasswd.com/"
                            TextWrapping="NoWrap" />

                        <TextBlock
                            Grid.Row="1"
                            Grid.Column="0"
                            VerticalAlignment="Center"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            Text="Sync Token" />
                        <PasswordBox
                            x:Name="syncBearerTokenBox"
                            Grid.Row="1"
                            Grid.Column="1"
                            MinHeight="28"
                            Padding="8,2"
                            PlaceholderText="Bearer token" />

                        <TextBlock
                            Grid.Row="2"
                            Grid.Column="0"
                            VerticalAlignment="Center"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            Text="Sync User ID" />
                        <TextBox
                            x:Name="syncUserIdTextBox"
                            Grid.Row="2"
                            Grid.Column="1"
                            MinHeight="28"
                            Padding="8,2"
                            PlaceholderText="HappyFactoryUserId"
                            TextWrapping="NoWrap" />

                        <TextBlock
                            Grid.Row="3"
                            Grid.Column="0"
                            VerticalAlignment="Center"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            Text="Snapshot History" />
                        <StackPanel
                            Grid.Row="3"
                            Grid.Column="1"
                            Orientation="Horizontal"
                            Spacing="8">
                            <ComboBox
                                x:Name="snapshotCandidatesCombo"
                                MinWidth="280"
                                PlaceholderText="No snapshot history" />
                            <Button
                                x:Name="refreshSnapshotCandidatesButton"
                                Click="refreshSnapshotCandidatesButton_Click"
                                Content="履歴を更新" />
                            <Button
                                x:Name="restoreSelectedSnapshotButton"
                                Click="restoreSelectedSnapshotButton_Click"
                                Content="選択した履歴を復元" />
                        </StackPanel>

                        <StackPanel
                            Grid.Row="0"
                            Grid.Column="2"
                            Grid.RowSpan="4"
                            Spacing="8">
                            <TextBlock
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                Style="{StaticResource CaptionTextBlockStyle}"
                                Text="基本操作" />
                            <StackPanel Spacing="8">
                                <Button
                                    x:Name="loadSyncSettingsButton"
                                    Click="loadSyncSettingsButton_Click"
                                    Content="保存済み設定を読み込む" />
                                <Button
                                    x:Name="saveSyncSettingsButton"
                                    Click="saveSyncSettingsButton_Click"
                                    Content="設定を保存する"
                                    Style="{StaticResource AccentButtonStyle}" />
                                <Button
                                    x:Name="testSyncConnectionButton"
                                    Click="testSyncConnectionButton_Click"
                                    Content="接続を確認する" />
                                <Button
                                    x:Name="manualSyncButton"
                                    Click="manualSyncButton_Click"
                                    Content="今すぐ同期する" />
                                <Button
                                    x:Name="restoreSyncSnapshotButton"
                                    Click="restoreSyncSnapshotButton_Click"
                                    Content="最新スナップショットを復元する" />
                            </StackPanel>
                            <TextBlock
                                Margin="0,8,0,0"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                Style="{StaticResource CaptionTextBlockStyle}"
                                Text="保守・復旧 / 開発向け" />
                            <StackPanel Spacing="8">
                                <Button
                                    x:Name="showSyncedVaultButton"
                                    Click="showSyncedVaultButton_Click"
                                    Content="同期済み Vault を表示する" />
                                <Button
                                    x:Name="clearLocalVaultButton"
                                    Click="clearLocalVaultButton_Click"
                                    Content="ローカル Vault を消去する" />
                                <Button
                                    x:Name="runVaultSchemaSelfTestButton"
                                    Click="runVaultSchemaSelfTestButton_Click"
                                    Content="Vault 自己テストを実行する（開発用）" />
                            </StackPanel>
                        </StackPanel>
                    </Grid>

                    <TextBlock
                        x:Name="syncStatusTextBlock"
                        Grid.Row="2"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Text="Sync status: Not synced yet"
                        TextWrapping="WrapWholeWords" />

                    <TextBlock
                        x:Name="syncHowToTextBlock"
                        Grid.Row="3"
                        Margin="0,8,0,0"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Text="How to (2 devices / profiles): 1) Set Sync Base URL/Token/User ID + Vault Recovery Code on both devices. 2) On device A, Create Vault Passkey then Resync Now. 3) On device B, Clear Local Vault then Resync Now (auto restore_snapshot)."
                        TextWrapping="WrapWholeWords" />

                    <TextBox
                        x:Name="syncedVaultTextBox"
                        Grid.Row="4"
                        Margin="0,8,0,0"
                        AcceptsReturn="True"
                        FontFamily="Cascadia Code"
                        FontSize="12"
                        IsReadOnly="True"
                        PlaceholderText="Synced Vault (decrypted) will appear here"
                        ScrollViewer.VerticalScrollBarVisibility="Auto"
                        TextWrapping="Wrap" />
                </Grid>
            </Grid>


            <TextBlock
                Grid.Row="4"
                Margin="0,16,0,0"
                Style="{StaticResource BodyStrongTextBlockStyle}"
                Text="Credentials" />
            <StackPanel
                Grid.Row="5"
                Orientation="Horizontal"
                Spacing="8">
                <Button
                    x:Name="refreshButton"
                    Click="refreshButton_Click"
                    Content="一覧を更新"
                    Style="{StaticResource AccentButtonStyle}" />
                <Button
                    x:Name="quickCreateVaultPasskeyButton"
                    Click="runVaultRecoveryButton_Click"
                    Content="Vault 用パスキーを作成" />
                <DropDownButton Content="追加">
                    <DropDownButton.Flyout>
                        <MenuFlyout Placement="Bottom">
                            <MenuFlyoutItem Click="addAllPluginCredentials_Click" Text="すべてのパスキーをキャッシュへ追加" />
                            <MenuFlyoutItem
                                x:Name="selectedAddButton"
                                Click="addSelectedCredentials_Click"
                                IsEnabled="False"
                                Text="選択したパスキーをキャッシュへ追加" />
                        </MenuFlyout>
                    </DropDownButton.Flyout>
                </DropDownButton>
                <DropDownButton Content="削除">
                    <DropDownButton.Flyout>
                        <MenuFlyout Placement="Bottom">
                            <MenuFlyoutItem Click="deleteAllPluginCredentials_Click" Text="すべてのパスキーをキャッシュから削除" />
                            <MenuFlyoutItem
                                x:Name="deleteSelectedCacheButton"
                                Click="deleteSelectedPluginCredentials_Click"
                                Text="選択したパスキーをキャッシュから削除" />
                            <MenuFlyoutItem
                                x:Name="deleteSelectedLocalButton"
                                Click="deleteSelectedPluginCredentialsEverywhere_Click"
                                Text="選択したパスキーを全保存先から削除" />
                            <MenuFlyoutItem Click="deleteAllLocalCredentials_Click" Text="すべてのパスキーをローカルから削除" />
                            <MenuFlyoutItem Click="deleteAllCredentials_Click" Text="すべてのパスキーを全保存先から削除" />
                        </MenuFlyout>
                    </DropDownButton.Flyout>
                </DropDownButton>
            </StackPanel>
            <Grid
                Grid.Row="6"
                VerticalAlignment="Stretch"
                Style="{StaticResource CardStyle}">
                <ListView
                    x:Name="credentialListView"
                    IsItemClickEnabled="False"
                    ItemsSource="{x:Bind CredentialList.credentials}"
                    SelectionChanged="SelectionChanged"
                    SelectionMode="Multiple">
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="local:Credential">
                            <Grid Padding="8" ColumnSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="28" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <FontIcon
                                    Grid.RowSpan="3"
                                    Grid.Column="0"
                                    FontSize="16"
                                    Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"
                                    Glyph="&#xF427;" />
                                <TextBlock Grid.Column="1" Text="{x:Bind UserName}" />
                                <TextBlock
                                    Grid.Row="1"
                                    Grid.Column="1"
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                    Style="{StaticResource CaptionTextBlockStyle}"
                                    Text="{x:Bind RpName}" />
                                <TextBlock
                                    Grid.Row="2"
                                    Grid.Column="1"
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                    Style="{StaticResource CaptionTextBlockStyle}">
                                    <Run Text="作成: " />
                                    <Run Text="{x:Bind CreatedAtDisplay}" />
                                    <Run Text="  更新: " />
                                    <Run Text="{x:Bind UpdatedAtDisplay}" />
                                </TextBlock>
                                <Border
                                    Grid.RowSpan="3"
                                    Grid.Column="2"
                                    Padding="4"
                                    VerticalAlignment="Center"
                                    Background="{ThemeResource ControlAltFillColorSecondaryBrush}"
                                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                    BorderThickness="1"
                                    CornerRadius="{StaticResource ControlCornerRadius}"
                                    Visibility="{x:Bind CredentialOptions, Converter={StaticResource BitwiseFlagToVisibilityConverter}, ConverterParameter=AutofillCapable}">
                                    <TextBlock FontSize="12" Text="Autofill" />
                                </Border>
                                <Border
                                    Grid.RowSpan="3"
                                    Grid.Column="3"
                                    Padding="4"
                                    VerticalAlignment="Center"
                                    Background="{ThemeResource SystemFillColorCriticalBackgroundBrush}"
                                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                    BorderThickness="1"
                                    CornerRadius="{StaticResource ControlCornerRadius}"
                                    Visibility="{x:Bind CredentialOptions, Converter={StaticResource BitwiseFlagToVisibilityConverter}, ConverterParameter=MetadataStale}">
                                    <TextBlock
                                        FontSize="12"
                                        Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                                        Text="Stale" />
                                </Border>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>

            <TextBlock
                Grid.Row="4"
                Grid.Column="1"
                Margin="0,16,0,0"
                Style="{StaticResource BodyStrongTextBlockStyle}"
                Text="Logs" />
            <Grid
                Grid.Row="6"
                Grid.Column="1"
                VerticalAlignment="Stretch"
                Style="{StaticResource CardStyle}">
                <Grid RowSpacing="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock
                        x:Name="logDetailTextBlock"
                        Grid.Row="0"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Text="Latest detail: Not available"
                        TextWrapping="WrapWholeWords" />
                    <TextBox
                        x:Name="syncHistoryTextBox"
                        Grid.Row="1"
                        AcceptsReturn="True"
                        FontFamily="Cascadia Code"
                        FontSize="12"
                        IsReadOnly="True"
                        ScrollViewer.VerticalScrollBarVisibility="Auto"
                        TextWrapping="Wrap" />
                </Grid>
            </Grid>
            <StackPanel
                Grid.Row="5"
                Grid.Column="1"
                Orientation="Horizontal"
                Spacing="8">
                <ComboBox
                    x:Name="logsFilterCombo"
                    MinWidth="160"
                    PlaceholderText="Filter logs"
                    SelectedIndex="0"
                    SelectionChanged="logsFilterCombo_SelectionChanged">
                    <x:String>All</x:String>
                    <x:String>Info</x:String>
                    <x:String>Warning</x:String>
                    <x:String>Failed</x:String>
                    <x:String>Success</x:String>
                </ComboBox>
                <Button
                    x:Name="copyLatestLogButton"
                    Click="copyLatestLogButton_Click"
                    Content="表示中ログをコピー" />
                <Button
                    x:Name="clearLogsButton"
                    Click="clearLogsButton_Click"
                    Content="ログ表示をクリア" />
            </StackPanel>
                </Grid>
            </ScrollViewer>
        </Grid>
    </Grid>
</Page>
