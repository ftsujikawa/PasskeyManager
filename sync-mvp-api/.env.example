# sync-mvp-api runtime configuration
# Copy this file to /opt/sync-mvp-api/.env and set secure values before enabling service.

# Required in production.
# Generate example: openssl rand -base64 48 | tr -d '\n'
TSUPASSWD_SYNC_BEARER_TOKEN=replace-with-strong-random-token

# Persistence paths (must be writable by service user, default: www-data)
TSUPASSWD_SYNC_DB_PATH=/opt/sync-mvp-api/data/vault-store.db
TSUPASSWD_SYNC_STORE_PATH=/opt/sync-mvp-api/data/vault-store.json

# Rate limit tuning
TSUPASSWD_SYNC_RATE_LIMIT_PER_MINUTE=60
TSUPASSWD_SYNC_RATE_LIMIT_QUEUE_LIMIT=0

# Bind to loopback and expose via reverse proxy (nginx/caddy)
ASPNETCORE_URLS=http://127.0.0.1:8088
